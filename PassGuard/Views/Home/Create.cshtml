@model PassGuard.Models.ViewModels.PropertyViewModel

@{
    ViewData["Title"] = "Add Property";
}

<h2>Add Property</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="EstateName" class="form-label">Estate Name</label>
        <input asp-for="EstateName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="OwnerUserId" class="form-label">Owner User Id</label>
        <select asp-for="OwnerUserId" asp-items="ViewBag.HomeOwnerUsers" class="form-control">
            <option value="">Select homeowner</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Address" class="form-label">Home Address</label>
        <input asp-for="Address" class="form-control" />
    </div>

    <hr />

    <h4>Visitor Info</h4>

    <div class="mb-3">
        <label asp-for="VisitorId" class="form-label">Visitor</label>
        <select asp-for="VisitorId" asp-items="ViewBag.Visitors" class="form-control">
            <option value="">Select visitor</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
</form>
